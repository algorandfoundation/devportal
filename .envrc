# ─────────────────────────────────────────────────────────────
# Environment Configuration (**ONLY STORE NON-SENSITIVE VALUES HERE**)
# Install the 1Password CLI (AF Team only) and import secrets from the appropriate vault.
# Run `direnv allow` after creating this file
# ─────────────────────────────────────────────────────────────

# Prose Check Configuration
export OPENAI_API_KEY=$(op read "op://Engineering/Algorand Developer Portal/API Tokens/OPENAI_API_KEY" 2>/dev/null || echo "")
export PROSE_CHECK_MODE=warn
export PROSE_CHECK_MODEL=gpt-4o-mini
export PROSE_CHECK_SENSITIVITY=medium
export PROSE_CHECK_EXCLUDE=src/content/docs/reference/
export PROSE_CHECK_ENABLED=false
