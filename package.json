{
  "name": "algorand-devportal",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "predev": "pnpm run generate-opcode-list",
    "prebuild": "pnpm run generate-opcode-list",
    "build": "astro check && astro build",
    "lint:fix": "eslint . && prettier -c ./src/** --write && astro check",
    "lint": "eslint . && prettier -c ./src/** && astro check",
    "preview": "astro preview",
    "astro": "astro",
    "validate:links": "pkill -f 'astro preview' || true; pkill -f 'astro dev' || true; pnpm run preview & sleep 3 && lychee --config ./lychee.toml --base-url 'http://localhost:4321' './dist/**/*.html'",
    "_section:utils": "====================== Helper Scripts ======================",
    "generate-opcode-list": "npx tsx scripts/generate-opcode-list.js",
    "prose:check": "npx tsx scripts/prose-check.ts $(git diff --name-only --cached -- 'src/content/docs/**/*.md' 'src/content/docs/**/*.mdx' | tr '\\n' ' ')",
    "prose:check:all": "find src/content/docs -name '*.md' -o -name '*.mdx' | xargs npx tsx scripts/prose-check.ts",
    "_section:github-imports": "====================== GitHub Imports ======================",
    "import:docs": "IMPORT_GITHUB=true astro sync && pnpm run sidebar:generate && pnpm run lint:fix",
    "import:force": "FORCE_IMPORT=true pnpm run import:docs",
    "import:dry-run": "IMPORT_GITHUB=true IMPORT_DRY_RUN=true astro sync",
    "import:clear": "tsx scripts/clean-docs-import.ts",
    "_section:sidebar": "====================== Sidebar Scripts ======================",
    "sidebar:generate": "npx tsx scripts/manage-sidebar-meta.js --clean && npx tsx scripts/manage-sidebar-meta.js",
    "sidebar:update": "npx tsx scripts/manage-sidebar-meta.js --update",
    "sidebar:overwrite": "npx tsx scripts/manage-sidebar-meta.js --overwrite",
    "sidebar:preview": "npx tsx scripts/manage-sidebar-meta.js --dry-run",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/markdown-remark": "^6.3.10",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/starlight": "^0.37.6",
    "@astrojs/starlight-tailwind": "^4.0.2",
    "@astrojs/tailwind": "^6.0.2",
    "@catppuccin/palette": "^1.7.1",
    "@catppuccin/vscode": "^3.18.1",
    "@larkiny/astro-github-loader": "^0.13.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/js-yaml": "^4.0.9",
    "astro": "^5.17.1",
    "astro-d2": "^0.9.0",
    "astro-icon": "^1.1.5",
    "astro-rehype-relative-markdown-links": "^0.18.1",
    "astro-remote": "^0.3.4",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.1",
    "octokit": "^5.0.5",
    "picomatch": "^4.0.3",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype": "^13.0.2",
    "rehype-external-links": "^3.0.0",
    "sharp": "^0.34.5",
    "starlight-auto-sidebar": "^0.1.4",
    "starlight-image-zoom": "^0.13.2",
    "starlight-links-validator": "^0.19.2",
    "starlight-llms-txt": "^0.7.0",
    "starlight-openapi": "^0.22.0",
    "tailwindcss": "^4.1.18",
    "widdershins": "^4.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@eslint/js": "^9.39.2",
    "@types/eslint__js": "^9.14.0",
    "@types/node": "^25.2.2",
    "@types/picomatch": "^4.0.2",
    "@typescript-eslint/parser": "^8.55.0",
    "dotenv": "^17.2.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "handlebars": "^4.7.8",
    "husky": "^9.1.7",
    "openai": "^6.21.0",
    "pnpm": "^10.29.3",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": "^10.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
