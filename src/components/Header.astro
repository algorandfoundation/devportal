---
import config from 'virtual:starlight/user-config';

import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import Search from './Search.astro';
import SiteTitle from './SiteTitle.astro';
import SocialIcons from './SocialIcons.astro';
import ThemeSelect from './ThemeSelect.astro';
import Default from '@astrojs/starlight/components/Header.astro';
import LibrarySwitcher from './LibrarySwitcher.astro';
import AIChatTrigger from './AIChatTrigger.tsx';
import { getLibraryFromPath } from '../config/libraries';

/**
 * Render the `Search` component if Pagefind is enabled or the default search component has been overridden.
 */
const shouldRenderSearch =
  config.pagefind ||
  config.components.Search !== '@astrojs/starlight/components/Search.astro';
const isHomepage = Astro.locals.starlightRoute.id === 'index.mdx';
const currentPath = Astro.url.pathname;
const activeLibrary = getLibraryFromPath(currentPath);
---

{
  isHomepage ? (
    <div class='header sl-flex mx-auto px-4 md:px-9 gap-0!'>
      <div class='grid w-full! max-w-[94px]! md:max-w-[113px]! h-[30px] md:h-[36px] mr-4! mb-[10px]!'>
        <SiteTitle />
      </div>
      <div class='sl-flex ml-auto! gap-2 items-center'>
        {shouldRenderSearch && <Search {...Astro.props} />}
        <AIChatTrigger client:idle />
      </div>
      <div class='sl-flex right-group gap-x-7! ml-7!'>
        <div class='sl-flex social-icons text-algo-lavender-400 dark:text-algo-teal-700'>
          <SocialIcons
            {...Astro.props}
            singleDisplayedSocial='github'
            size='20px'
          />
        </div>
        <ThemeSelect classList='text-algo-lavender-200 dark:text-algo-teal-300 p-0! m-0!' />
        <LanguageSelect {...Astro.props} />
      </div>
    </div>
  ) : activeLibrary ? (
    /* Library pages: custom header with hamburger nav to the left of logo */
    <div class='header library-header'>
      <div class='library-title-area sl-flex'>
        <library-header-toggle class='library-nav-toggle'>
          <button
            class='library-nav-btn'
            aria-expanded='false'
            aria-controls='library-nav-panel'
            title='Switch library'
          >
            <svg
              width='20'
              height='20'
              viewBox='0 0 20 20'
              fill='currentColor'
              aria-hidden='true'
            >
              <rect x='2' y='4' width='16' height='1.8' rx='0.9' />
              <rect x='2' y='9.1' width='16' height='1.8' rx='0.9' />
              <rect x='2' y='14.2' width='16' height='1.8' rx='0.9' />
            </svg>
          </button>
          <div
            class='library-nav-panel'
            id='library-nav-panel'
            aria-hidden='true'
          >
            <div class='library-nav-panel-inner'>
              <a href='/getting-started/introduction/' class='panel-nav-link'>
                <svg
                  width='14'
                  height='14'
                  viewBox='0 0 14 14'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='1.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  aria-hidden='true'
                >
                  <path d='M7 1L1 6V13H5V9H9V13H13V6L7 1Z' />
                </svg>
                Learn Algorand
              </a>
              <a href='/docs/' class='panel-nav-link'>
                <svg
                  width='14'
                  height='14'
                  viewBox='0 0 14 14'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='1.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  aria-hidden='true'
                >
                  <path d='M2 2H9L12 5V12H2V2Z' />
                  <path d='M5 7H9' />
                  <path d='M5 9.5H9' />
                </svg>
                Library Docs
              </a>
              <div class='panel-divider' />
              <LibrarySwitcher currentPath={currentPath} compact />
            </div>
          </div>
        </library-header-toggle>
        <SiteTitle />
      </div>
      <div class='sl-flex print:hidden gap-2 items-center'>
        {shouldRenderSearch && <Search {...Astro.props} />}
        <AIChatTrigger client:idle />
      </div>
      <div class='sl-hidden md:sl-flex print:hidden right-group'>
        <div class='sl-flex social-icons'>
          <SocialIcons {...Astro.props} />
        </div>
        <ThemeSelect />
        <LanguageSelect {...Astro.props} />
      </div>
    </div>
  ) : (
    /* Default pages: wrap Starlight header to inject AI trigger */
    <div class='header default-header'>
      <div class='default-header-content'>
        <Default {...Astro.props} />
      </div>
      <div class='sl-flex print:hidden gap-2 items-center default-ai-trigger'>
        <AIChatTrigger client:idle />
      </div>
    </div>
  )
}

<script>
  class LibraryHeaderToggle extends HTMLElement {
    private btn!: HTMLButtonElement;
    private panel!: HTMLElement;

    connectedCallback() {
      this.btn = this.querySelector('.library-nav-btn')!;
      this.panel = this.querySelector('.library-nav-panel')!;
      if (!this.btn || !this.panel) return;

      this.btn.addEventListener('click', () => this.toggle());
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && this.isOpen()) this.close();
      });
      document.addEventListener('click', e => {
        if (this.isOpen() && !this.contains(e.target as Node)) this.close();
      });
    }

    isOpen() {
      return this.btn.getAttribute('aria-expanded') === 'true';
    }

    toggle() {
      if (this.isOpen()) this.close();
      else this.open();
    }

    open() {
      this.btn.setAttribute('aria-expanded', 'true');
      this.panel.setAttribute('aria-hidden', 'false');
    }

    close() {
      this.btn.setAttribute('aria-expanded', 'false');
      this.panel.setAttribute('aria-hidden', 'true');
    }
  }

  customElements.define('library-header-toggle', LibraryHeaderToggle);
</script>

<style>
  .header {
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  .title-wrapper {
    /* Prevent long titles overflowing and covering the search and menu buttons on narrow viewports. */
    overflow: hidden;
  }

  .right-group,
  .social-icons {
    gap: 1rem;
    align-items: center;
  }

  .social-icons::after {
    content: '';
    height: 2rem;
    border-inline-end: 1px solid var(--sl-color-gray-5);
  }

  /* Library header: hamburger + logo with no overflow:clip */
  .library-header {
    display: flex;
  }

  .library-title-area {
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  /* Library nav hamburger toggle */
  .library-nav-toggle {
    display: flex;
    align-items: center;
    position: relative;
  }

  .library-nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    padding: 0.4rem;
    border-radius: 0.375rem;
    transition:
      color 0.15s,
      background-color 0.15s;
  }

  .library-nav-btn:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }

  .library-nav-btn[aria-expanded='true'] {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
  }

  /* Dropdown panel */
  .library-nav-panel {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 100;
    min-width: 240px;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    margin-top: 0.5rem;
    display: none;
  }

  .library-nav-panel[aria-hidden='false'] {
    display: block;
  }

  .library-nav-panel-inner {
    padding: 0.5rem;
  }

  .panel-nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.5rem;
    border-radius: 0.25rem;
    text-decoration: none;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    transition:
      color 0.15s,
      background-color 0.15s;
  }

  .panel-nav-link:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }

  .panel-divider {
    height: 1px;
    background-color: var(--sl-color-hairline-light);
    margin: 0.4rem 0;
  }

  @media (min-width: 50rem) {
    :global(:root[data-has-sidebar]) {
      --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
    }
    :global(:root:not([data-has-toc])) {
      --__toc-width: 0rem;
    }
    .header {
      --__sidebar-width: max(
        0rem,
        var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x)
      );
      --__main-column-fr: calc(
        (
            100% + var(--__sidebar-pad, 0rem) -
              var(--__toc-width, var(--sl-sidebar-width)) -
              (2 * var(--__toc-width, var(--sl-nav-pad-x))) -
              var(--sl-content-inline-start, 0rem) - var(--sl-content-width)
          ) /
          2
      );
      display: grid;
      grid-template-columns:
        /* 1 (site title): runs up until the main content column's left edge or the width of the title, whichever is the largest  */
        minmax(
          calc(
            var(--__sidebar-width) +
              max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))
          ),
          auto
        )
        /* 2 (search box): all free space that is available. */
        1fr
        /* 3 (right items): use the space that these need. */
        auto;
      align-content: center;
    }
  }

  /* Default header wrapper for non-homepage, non-library pages */
  .default-header {
    display: flex;
    width: 100%;
  }

  .default-header-content {
    flex: 1;
    min-width: 0;
  }

  .default-ai-trigger {
    margin-left: 0.5rem;
    align-items: center;
  }
</style>
