---
/**
 * HeaderMenu - Hamburger navigation menu for library pages.
 *
 * Renders a hamburger button that opens a dropdown panel with:
 * - Navigation links back to main site areas
 * - LibraryPicker in compact mode (library list with LinkChip variant links)
 */
import LibraryPicker from './LibraryPicker.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<library-header-menu class='header-menu'>
  <button
    class='menu-btn'
    aria-expanded='false'
    aria-controls='header-menu-panel'
    aria-label='Site navigation'
  >
    <svg
      width='20'
      height='20'
      viewBox='0 0 20 20'
      fill='currentColor'
      aria-hidden='true'
    >
      <rect x='2' y='4' width='16' height='1.8' rx='0.9'></rect>
      <rect x='2' y='9.1' width='16' height='1.8' rx='0.9'></rect>
      <rect x='2' y='14.2' width='16' height='1.8' rx='0.9'></rect>
    </svg>
  </button>

  <div class='menu-panel' id='header-menu-panel' aria-hidden='true'>
    <div class='menu-panel-inner'>
      <a href='/getting-started/portal-guide/' class='menu-nav-link'>
        <svg
          width='14'
          height='14'
          viewBox='0 0 14 14'
          fill='none'
          stroke='currentColor'
          stroke-width='1.5'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
        >
          <path d='M7 1L1 6V13H5V9H9V13H13V6L7 1Z'></path>
        </svg>
        Learn Algorand
      </a>
      <a href='/docs/' class='menu-nav-link'>
        <svg
          width='14'
          height='14'
          viewBox='0 0 14 14'
          fill='none'
          stroke='currentColor'
          stroke-width='1.5'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
        >
          <path d='M2 2H9L12 5V12H2V2Z'></path>
          <path d='M5 7H9'></path>
          <path d='M5 9.5H9'></path>
        </svg>
        Library Docs
      </a>
      <div class='menu-divider'></div>
      <LibraryPicker currentPath={currentPath} compact />
    </div>
  </div>
</library-header-menu>

<script>
  class LibraryHeaderMenu extends HTMLElement {
    private btn!: HTMLButtonElement;
    private panel!: HTMLElement;
    private onKeydown = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && this.isOpen()) this.close();
    };
    private onClickOutside = (e: MouseEvent) => {
      if (this.isOpen() && !this.contains(e.target as Node)) this.close();
    };

    connectedCallback() {
      this.btn = this.querySelector('.menu-btn')!;
      this.panel = this.querySelector('.menu-panel')!;
      if (!this.btn || !this.panel) return;

      this.btn.addEventListener('click', () => this.toggle());
      document.addEventListener('keydown', this.onKeydown);
      document.addEventListener('click', this.onClickOutside);
    }

    disconnectedCallback() {
      document.removeEventListener('keydown', this.onKeydown);
      document.removeEventListener('click', this.onClickOutside);
    }

    isOpen() {
      return this.btn.getAttribute('aria-expanded') === 'true';
    }

    toggle() {
      if (this.isOpen()) this.close();
      else this.open();
    }

    open() {
      this.btn.setAttribute('aria-expanded', 'true');
      this.panel.setAttribute('aria-hidden', 'false');
    }

    close() {
      this.btn.setAttribute('aria-expanded', 'false');
      this.panel.setAttribute('aria-hidden', 'true');
    }
  }

  customElements.define('library-header-menu', LibraryHeaderMenu);
</script>

<style>
  .header-menu {
    display: flex;
    align-items: center;
    position: relative;
  }

  .menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    padding: 0.4rem;
    border-radius: 0.375rem;
    transition:
      color 0.15s,
      background-color 0.15s;
  }

  .menu-btn:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }

  .menu-btn[aria-expanded='true'] {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
  }

  .menu-panel {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 100;
    min-width: 240px;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    margin-top: 0.5rem;
    display: none;
  }

  .menu-panel[aria-hidden='false'] {
    display: block;
  }

  .menu-panel-inner {
    padding: 0.5rem;
  }

  .menu-nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.5rem;
    border-radius: 0.25rem;
    text-decoration: none;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    transition:
      color 0.15s,
      background-color 0.15s;
  }

  .menu-nav-link:hover {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }

  .menu-divider {
    height: 1px;
    background-color: var(--sl-color-hairline-light);
    margin: 0.4rem 0;
  }
</style>
