---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  width: number;
  height: number;
}

const { src, alt, width, height } = Astro.props;
---

<figure>
  <Image src={src} alt={alt} width={width} height={height} />
  <figcaption>{alt}</figcaption>
</figure>
