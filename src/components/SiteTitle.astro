---
// @ts-expect-error — virtual module has no type declarations
import { logos } from 'virtual:starlight/user-images';
import config from 'virtual:starlight/user-config';
import AltDarkLogo from '../assets/images/portal-logo-dark-mode-alt.svg';
import { getLibraryFromPath } from '../config/libraries';

interface Props {
  isFooter?: boolean;
}

const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;

const { isFooter } = Astro.props;
const isHomepage = Astro.locals.starlightRoute.id === 'index.mdx';
const currentPath = Astro.url.pathname;

// Footer always shows the site logo, never a library logo
const activeLibrary = !isFooter ? getLibraryFromPath(currentPath) : undefined;

const libraryLogo = activeLibrary?.logo;

// Site logo sources (library logo renders separately as inline SVG)
const darkLogoSrc = isFooter ? AltDarkLogo.src : logos.dark.src;
const lightLogoSrc = isFooter ? logos.dark.src : logos.light?.src;
const darkWidth = logos.dark.width;
const darkHeight = logos.dark.height;
const lightWidth = isFooter ? logos.dark.width : logos.light?.width;
const lightHeight = isFooter ? logos.dark.height : logos.light?.height;

const logoHref = activeLibrary ? `/docs/${activeLibrary.slug}/` : siteTitleHref;
---

<a href={logoHref} class='site-title sl-flex'>
  {
    libraryLogo ? (
      <span
        class='library-logo'
        role='img'
        aria-label={activeLibrary?.label}
        set:html={libraryLogo}
      />
    ) : config.logo && logos.dark ? (
      <>
        <img
          class:list={{
            'light:sl-hidden print:hidden': !('src' in config.logo),
            'h-full!': isHomepage,
          }}
          alt={`light theme ${config.logo.alt}`}
          src={darkLogoSrc}
          width={darkWidth}
          height={darkHeight}
        />
        {!('src' in config.logo) && (
          <img
            class:list={[
              'dark:sl-hidden print:block',
              {
                'h-full!': isHomepage,
              },
            ]}
            alt={`dark theme ${config.logo.alt}`}
            src={lightLogoSrc}
            width={lightWidth}
            height={lightHeight}
          />
        )}
      </>
    ) : null
  }
  <span class:list={{ 'sr-only': config.logo?.replacesTitle }} translate='no'>
    {siteTitle}
  </span>
</a>

<style>
  .site-title {
    align-items: center;
    gap: var(--sl-nav-gap);
    font-size: var(--sl-text-h4);
    font-weight: 600;
    color: var(--sl-color-text-accent);
    text-decoration: none;
    white-space: nowrap;
  }
  img {
    height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
    width: auto;
    max-width: 100%;
    object-fit: contain;
    object-position: 0 50%;
  }
  .library-logo {
    display: flex;
    align-items: center;
    height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
    line-height: 0;
    color: var(--sl-color-white);
  }
  .library-logo :global(svg) {
    height: 100%;
    width: auto;
  }
</style>
