---
/**
 * LibraryPicker - Sidebar library navigation.
 *
 * Renders either:
 * - a compact, always-visible TanStack-style library list
 * - or a dropdown list (legacy mode)
 */
import {
  libraries,
  buildLibraryUrl,
  type LibraryConfig,
} from '../config/libraries';
import { langIcons } from '../config/lang-icons';

interface Props {
  currentPath: string;
  /** When true, renders the library list directly instead of a dropdown. */
  compact?: boolean;
}

const { currentPath, compact = false } = Astro.props;
const isLibraryPage = currentPath.startsWith('/docs/');

const categoryOrder = ['sdk', 'cli', 'language', 'tool', 'api'];
const categories: Record<string, LibraryConfig[]> = {};
for (const lib of libraries) {
  if (!categories[lib.category]) categories[lib.category] = [];
  categories[lib.category].push(lib);
}

interface CompactEntry {
  href: string;
  isActive: boolean;
  label: string;
}

interface AreaEntry {
  href: string;
  isActive: boolean;
  label: string;
}

const areaEntry: AreaEntry = {
  href: '/concepts/smart-contracts/overview/',
  isActive:
    !currentPath.startsWith('/docs/') && currentPath.startsWith('/concepts/'),
  label: 'Main Docs',
};

function buildPrimaryLibraryHref(
  lib: LibraryConfig,
  defaultVersion: string,
): string {
  const defaultLanguage = lib.languages[0];
  return defaultLanguage
    ? buildLibraryUrl(lib, defaultLanguage, defaultVersion)
    : `/docs/${lib.slug}/`;
}

function buildCompactEntries(lib: LibraryConfig, currentPath: string): CompactEntry[] {
  const defaultVersion = lib.versions[0]?.slug ?? 'latest';

  if (lib.languages.length <= 1) {
    const href = buildPrimaryLibraryHref(lib, defaultVersion);
    return [
      {
        href,
        isActive: currentPath.startsWith(href),
        label: lib.label,
      },
    ];
  }

  return lib.languages.map(lang => {
    const href = buildLibraryUrl(lib, lang, defaultVersion);
    const normalizedLabel = lib.label.toLowerCase();
    const normalizedLang = lang.toLowerCase();
    const label = normalizedLabel.includes(normalizedLang)
      ? lib.label
      : `${lib.label} ${lang}`;

    return {
      href,
      isActive: currentPath.startsWith(href),
      label,
    };
  });
}
---

{
  compact ? (
    <div class='library-picker compact'>
      {isLibraryPage && (
        <a class='picker-heading picker-heading-link' href={areaEntry.href}>
          <span aria-hidden='true'>←</span>
          <span>Back to Concepts</span>
        </a>
      )}

      <details class='picker-group' open>
        <summary class='picker-heading picker-heading-toggle'>
          <span>Library Docs</span>
          <svg
            class='picker-heading-chevron'
            width='12'
            height='12'
            viewBox='0 0 12 12'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M3 5L6 8L9 5'
              stroke='currentColor'
              stroke-width='1.5'
              stroke-linecap='round'
              stroke-linejoin='round'
            />
          </svg>
        </summary>
        <ul class='picker-list' role='list'>
          {categoryOrder.map(cat =>
            categories[cat]?.map(lib => {
              return buildCompactEntries(lib, currentPath).map(entry => (
                <li>
                  <a
                  class:list={[
                    'picker-item',
                    'picker-item-static',
                    { active: entry.isActive },
                  ]}
                  href={entry.href}
                >
                    <span class='picker-item-label'>{entry.label}</span>
                  </a>
                </li>
              ));
            }),
          )}
        </ul>
      </details>
    </div>
  ) : (
    <library-picker class='library-picker'>
      <button
        class='picker-btn'
        aria-expanded='false'
        aria-controls='library-picker-panel'
      >
        <svg
          class='picker-icon'
          width='16'
          height='16'
          viewBox='0 0 16 16'
          fill='none'
          stroke='currentColor'
          stroke-width='1.5'
          stroke-linecap='round'
          stroke-linejoin='round'
          aria-hidden='true'
        >
          <path d='M2 3H14' />
          <path d='M2 8H14' />
          <path d='M2 13H14' />
          <circle cx='5' cy='3' r='1.5' fill='currentColor' stroke='none' />
          <circle cx='10' cy='8' r='1.5' fill='currentColor' stroke='none' />
          <circle cx='7' cy='13' r='1.5' fill='currentColor' stroke='none' />
        </svg>
        <span class='picker-label'>APIs & Tools</span>
        <svg
          class='picker-chevron'
          width='12'
          height='12'
          viewBox='0 0 12 12'
          fill='none'
          aria-hidden='true'
        >
          <path
            d='M3 5L6 8L9 5'
            stroke='currentColor'
            stroke-width='1.5'
            stroke-linecap='round'
            stroke-linejoin='round'
          />
        </svg>
      </button>

      <div class='picker-panel' id='library-picker-panel' aria-hidden='true'>
        <ul class='picker-list' role='list'>
          {categoryOrder.map(cat =>
            categories[cat]?.map(lib => {
              const rootHref = `/docs/${lib.slug}/`;
              const isActive = currentPath.startsWith(rootHref);
              const defaultVersion = lib.versions[0]?.slug ?? 'latest';
              return (
                <li class:list={['picker-item', { active: isActive }]}>
                  <span
                    class='picker-dot'
                    style={`--dot-color: ${lib.color}`}
                  />
                  <div class='picker-item-main'>
                    <a
                      class='picker-item-link'
                      href={buildPrimaryLibraryHref(lib, defaultVersion)}
                    >
                      <span class='picker-item-label'>{lib.label}</span>
                    </a>
                    {lib.languages.length > 0 && (
                      <span class='picker-variants'>
                        {lib.languages.map((lang, index) => {
                          const icon = langIcons[lang];
                          const variantHref = buildLibraryUrl(
                            lib,
                            lang,
                            defaultVersion,
                          );
                          return (
                            <>
                              {index > 0 && (
                                <span
                                  class='picker-variant-separator'
                                  aria-hidden='true'
                                >
                                  ·
                                </span>
                              )}
                              <a
                                class='picker-variant-link'
                                href={variantHref}
                                style={
                                  icon
                                    ? `--variant-accent: ${icon.color}`
                                    : undefined
                                }
                              >
                                {lang}
                              </a>
                            </>
                          );
                        })}
                      </span>
                    )}
                  </div>
                </li>
              );
            }),
          )}
        </ul>
      </div>
    </library-picker>
  )
}

<script>
  class LibraryPicker extends HTMLElement {
    private btn!: HTMLButtonElement;
    private panel!: HTMLElement;

    connectedCallback() {
      this.btn = this.querySelector('.picker-btn')!;
      this.panel = this.querySelector('.picker-panel')!;
      if (!this.btn || !this.panel) return;

      this.btn.addEventListener('click', () => this.toggle());
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && this.isOpen()) this.close();
      });
      document.addEventListener('click', e => {
        if (this.isOpen() && !this.contains(e.target as Node)) this.close();
      });
    }

    isOpen() {
      return this.btn.getAttribute('aria-expanded') === 'true';
    }

    toggle() {
      if (this.isOpen()) this.close();
      else this.open();
    }

    open() {
      this.btn.setAttribute('aria-expanded', 'true');
      this.panel.setAttribute('aria-hidden', 'false');
    }

    close() {
      this.btn.setAttribute('aria-expanded', 'false');
      this.panel.setAttribute('aria-hidden', 'true');
    }
  }

  customElements.define('library-picker', LibraryPicker);
</script>

<style>
  .library-picker {
    display: block;
    padding: 0 0 0.5rem;
  }

  .library-picker.compact {
    padding: 0.55rem;
    margin-bottom: 0.25rem;
    background-color: color-mix(
      in oklab,
      var(--sl-color-bg-nav) 88%,
      var(--sl-color-gray-6)
    );
  }

  :root[data-theme='dark'] .library-picker.compact {
    background-color: color-mix(
      in oklab,
      var(--sl-color-bg-nav) 94%,
      white 6%
    );
  }

  .picker-heading {
    margin: 0 0 0.25rem;
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-2xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .picker-group {
    margin: 0;
  }

  .picker-heading-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    list-style: none;
  }

  .picker-heading-toggle::-webkit-details-marker {
    display: none;
  }

  .picker-heading-chevron {
    flex-shrink: 0;
    opacity: 0.75;
    transition: transform 0.2s ease;
  }

  .picker-group[open] .picker-heading-chevron {
    transform: rotate(180deg);
  }

  /* Trigger button */
  .picker-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem 0.6rem;
    background: none;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    color: var(--sl-color-white);
    cursor: pointer;
    font-size: var(--sl-text-base);
    font-weight: 600;
    text-align: left;
    transition:
      background-color 0.15s,
      border-color 0.15s;
  }

  @media (min-width: 50rem) {
    .picker-btn {
      font-size: var(--sl-text-sm);
    }
  }

  .picker-btn:hover {
    background-color: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
  }

  .picker-btn[aria-expanded='true'] {
    background-color: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
  }

  .picker-icon {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .picker-label {
    flex: 1;
  }

  .picker-chevron {
    flex-shrink: 0;
    opacity: 0.5;
    transition: transform 0.2s;
  }

  [aria-expanded='true'] .picker-chevron {
    transform: rotate(180deg);
  }

  /* Dropdown panel */
  .picker-panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height 0.25s ease,
      opacity 0.2s ease,
      margin 0.25s ease;
    margin-top: 0;
  }

  .picker-panel[aria-hidden='false'] {
    max-height: 60vh;
    opacity: 1;
    margin-top: 0.4rem;
    overflow-y: auto;
  }

  .picker-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .picker-area-list {
    margin-bottom: 0.45rem;
  }

  .picker-heading-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.45rem;
    padding: 0;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition:
      color 0.15s,
      opacity 0.15s;
  }

  .picker-heading-link:hover {
    color: var(--sl-color-white);
    opacity: 1;
  }

  .picker-heading-link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  /* Individual library item */
  .picker-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.45rem 0.5rem;
    border-radius: 0.25rem;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-base);
    line-height: 1.4;
  }

  .picker-item-static {
    align-items: center;
    padding: 0.28rem 0.3rem;
    text-decoration: none;
    font-size: var(--sl-text-sm);
  }

  .picker-item-area {
    gap: 0;
  }

  @media (min-width: 50rem) {
    .picker-item {
      font-size: var(--sl-text-sm);
    }
  }

  .picker-item:has(:hover) {
    background-color: var(--sl-color-gray-6);
  }

  .picker-item.active {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
  }

  :root[data-theme='dark'] .picker-item.active {
    background-color: color-mix(
      in oklab,
      var(--sl-color-accent) 18%,
      var(--sl-color-bg-nav)
    );
    color: var(--sl-color-white);
  }

  :root[data-theme='dark'] .picker-item:has(:hover) {
    background-color: color-mix(
      in oklab,
      var(--sl-color-accent) 10%,
      var(--sl-color-bg-nav)
    );
  }

  .picker-item-main {
    display: flex;
    flex: 1;
    flex-direction: column;
    min-width: 0;
    gap: 0.05rem;
  }

  .picker-item-link {
    display: inline-flex;
    min-width: 0;
    color: inherit;
    text-decoration: none;
    width: fit-content;
  }

  .picker-item-link:hover .picker-item-label {
    color: var(--sl-color-white);
  }

  .picker-item-link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
    border-radius: 0.25rem;
  }

  /* Library name label */
  .picker-item-label {
    white-space: normal;
    color: inherit;
  }

  .picker-item-static .picker-item-label {
    white-space: nowrap;
  }

  .picker-item-static .picker-dot {
    margin-top: 0;
  }

  .picker-item.active .picker-item-label {
    font-weight: 600;
  }

  .picker-variants {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-xs);
    line-height: 1.3;
  }

  .picker-variant-link {
    color: var(--variant-accent, var(--sl-color-gray-3));
    text-decoration: none;
  }

  .picker-variant-link:hover {
    color: var(--sl-color-white);
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .picker-variant-link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
    border-radius: 0.2rem;
  }

  .picker-variant-separator {
    color: var(--sl-color-gray-5);
  }
</style>
