---
/**
 * LibraryPicker - Compact dropdown for selecting a library in the main sidebar.
 *
 * Renders as a button that expands to show the full library list with:
 * - Colored dot per library
 * - Library name (links to library root)
 * - Clickable language icons that link directly to each variant
 */
import {
  libraries,
  buildLibraryUrl,
  type LibraryConfig,
} from '../config/libraries';
import { langIcons } from '../config/lang-icons';
import LinkChip from './LinkChip.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const categoryOrder = ['sdk', 'cli', 'language', 'tool', 'api'];
const categories: Record<string, LibraryConfig[]> = {};
for (const lib of libraries) {
  if (!categories[lib.category]) categories[lib.category] = [];
  categories[lib.category].push(lib);
}
---

<library-picker class='library-picker'>
  <button
    class='picker-btn'
    aria-expanded='false'
    aria-controls='library-picker-panel'
  >
    <svg
      class='picker-icon'
      width='16'
      height='16'
      viewBox='0 0 16 16'
      fill='none'
      stroke='currentColor'
      stroke-width='1.5'
      stroke-linecap='round'
      stroke-linejoin='round'
      aria-hidden='true'
    >
      <path d='M2 3H14'></path>
      <path d='M2 8H14'></path>
      <path d='M2 13H14'></path>
      <circle cx='5' cy='3' r='1.5' fill='currentColor' stroke='none'></circle>
      <circle cx='10' cy='8' r='1.5' fill='currentColor' stroke='none'></circle>
      <circle cx='7' cy='13' r='1.5' fill='currentColor' stroke='none'></circle>
    </svg>
    <span class='picker-label'>APIs & Tools</span>
    <svg
      class='picker-chevron'
      width='12'
      height='12'
      viewBox='0 0 12 12'
      fill='none'
      aria-hidden='true'
    >
      <path
        d='M3 5L6 8L9 5'
        stroke='currentColor'
        stroke-width='1.5'
        stroke-linecap='round'
        stroke-linejoin='round'></path>
    </svg>
  </button>

  <div class='picker-panel' id='library-picker-panel' aria-hidden='true'>
    <ul class='picker-list' role='list'>
      {
        categoryOrder.map(cat =>
          categories[cat]?.map(lib => {
            const rootHref = `/docs/${lib.slug}/`;
            const isActive = currentPath.startsWith(rootHref);
            const defaultVersion = lib.versions[0]?.slug ?? 'latest';
            return (
              <li class:list={['picker-item', { active: isActive }]}>
                <span class='picker-dot' style={`--dot-color: ${lib.color}`} />
                <a
                  href={rootHref}
                  class='picker-item-label'
                  aria-current={isActive ? 'page' : undefined}
                >
                  {lib.label}
                </a>
                {lib.languages.length > 0 && (
                  <span class='picker-variants'>
                    {lib.languages.map(lang => {
                      const icon = langIcons[lang];
                      if (!icon) return null;
                      const variantHref = buildLibraryUrl(
                        lib,
                        lang,
                        defaultVersion,
                      );
                      return (
                        <LinkChip
                          href={variantHref}
                          label={lang}
                          icon={icon.svg}
                          accentColor={icon.color}
                        />
                      );
                    })}
                  </span>
                )}
              </li>
            );
          }),
        )
      }
    </ul>
  </div>
</library-picker>

<script>
  class LibraryPicker extends HTMLElement {
    private btn!: HTMLButtonElement;
    private panel!: HTMLElement;

    connectedCallback() {
      this.btn = this.querySelector('.picker-btn')!;
      this.panel = this.querySelector('.picker-panel')!;
      if (!this.btn || !this.panel) return;

      this.btn.addEventListener('click', () => this.toggle());
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && this.isOpen()) this.close();
      });
      document.addEventListener('click', e => {
        if (this.isOpen() && !this.contains(e.target as Node)) this.close();
      });
    }

    isOpen() {
      return this.btn.getAttribute('aria-expanded') === 'true';
    }

    toggle() {
      if (this.isOpen()) this.close();
      else this.open();
    }

    open() {
      this.btn.setAttribute('aria-expanded', 'true');
      this.panel.setAttribute('aria-hidden', 'false');
    }

    close() {
      this.btn.setAttribute('aria-expanded', 'false');
      this.panel.setAttribute('aria-hidden', 'true');
    }
  }

  customElements.define('library-picker', LibraryPicker);
</script>

<style>
  .library-picker {
    display: block;
    padding: 0 0 0.5rem;
  }

  /* Trigger button */
  .picker-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem 0.6rem;
    background: none;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    color: var(--sl-color-white);
    cursor: pointer;
    font-size: var(--sl-text-base);
    font-weight: 600;
    text-align: left;
    transition:
      background-color 0.15s,
      border-color 0.15s;
  }

  @media (min-width: 50rem) {
    .picker-btn {
      font-size: var(--sl-text-sm);
    }
  }

  .picker-btn:hover {
    background-color: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
  }

  .picker-btn[aria-expanded='true'] {
    background-color: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
  }

  .picker-icon {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .picker-label {
    flex: 1;
  }

  .picker-chevron {
    flex-shrink: 0;
    opacity: 0.5;
    transition: transform 0.2s;
  }

  [aria-expanded='true'] .picker-chevron {
    transform: rotate(180deg);
  }

  /* Dropdown panel */
  .picker-panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height 0.25s ease,
      opacity 0.2s ease,
      margin 0.25s ease;
    margin-top: 0;
  }

  .picker-panel[aria-hidden='false'] {
    max-height: 60vh;
    opacity: 1;
    margin-top: 0.4rem;
    overflow-y: auto;
  }

  .picker-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Individual library item */
  .picker-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.5rem;
    border-radius: 0.25rem;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-base);
    line-height: 1.4;
  }

  @media (min-width: 50rem) {
    .picker-item {
      font-size: var(--sl-text-sm);
    }
  }

  .picker-item:has(:hover) {
    background-color: var(--sl-color-gray-6);
  }

  .picker-item.active {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
  }

  .picker-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--dot-color);
    flex-shrink: 0;
  }

  /* Library name link */
  .picker-item-label {
    flex: 1;
    min-width: 0;
    text-decoration: none;
    color: inherit;
    transition: color 0.15s;
  }

  .picker-item-label:hover {
    color: var(--sl-color-white);
  }

  .picker-item-label:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 1px;
  }

  .picker-item.active .picker-item-label {
    font-weight: 600;
  }

  /* Language variant links */
  .picker-variants {
    display: flex;
    gap: 0.3rem;
    flex-shrink: 0;
    margin-inline-start: auto;
  }
</style>
