---
/**
 * LibrarySwitcher - Shows the list of library virtual collections.
 *
 * Displayed at the top of the main site sidebar (like TanStack's library list).
 * Each library has a colored dot and label. Clicking navigates to that library's
 * isolated docs section.
 */
import { libraries, type LibraryConfig } from '../config/libraries';

interface Props {
  currentPath: string;
  /** When true, renders as a compact overlay (used inside library sidebar) */
  compact?: boolean;
}

const { currentPath, compact = false } = Astro.props;

// Group by category for the full view
const categories: Record<string, LibraryConfig[]> = {};
for (const lib of libraries) {
  if (!categories[lib.category]) categories[lib.category] = [];
  categories[lib.category].push(lib);
}
const categoryOrder = ['sdk', 'cli', 'language', 'tool', 'api'];
---

<nav class:list={['library-switcher', { compact }]} aria-label="Library documentation">
  {!compact && (
    <div class="switcher-header">
      <span class="switcher-title">Libraries & Tools</span>
    </div>
  )}
  <ul class="library-list" role="list">
    {categoryOrder.map((cat) =>
      categories[cat]?.map((lib) => {
        const href = `/docs/${lib.slug}/`;
        const isActive = currentPath.startsWith(href);
        return (
          <li>
            <a
              href={href}
              class:list={['library-item', { active: isActive }]}
              aria-current={isActive ? 'true' : undefined}
            >
              <span class="library-dot" style={`--dot-color: ${lib.color}`} />
              <span class="library-label">{lib.label}</span>
            </a>
          </li>
        );
      })
    )}
  </ul>
  {!compact && (
    <div class="switcher-divider" />
  )}
</nav>

<style>
  .library-switcher {
    padding: 0 0 0.5rem;
  }

  .library-switcher.compact {
    padding: 0;
  }

  .switcher-header {
    padding: 0.25rem 0.5rem 0.5rem;
  }

  .switcher-title {
    font-size: var(--sl-text-lg);
    font-weight: 600;
    color: var(--sl-color-white);
  }

  @media (min-width: 50rem) {
    .switcher-title {
      font-size: var(--sl-text-base);
    }
  }

  .library-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .library-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.35rem 0.5rem;
    border-radius: 0.25rem;
    text-decoration: none;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-base);
    line-height: 1.4;
    transition: color 0.15s, background-color 0.15s;
  }

  @media (min-width: 50rem) {
    .library-item {
      font-size: var(--sl-text-sm);
    }
  }

  .library-item:hover,
  .library-item:focus {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }

  .library-item.active {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-5);
    font-weight: 600;
  }

  .library-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--dot-color);
    flex-shrink: 0;
  }

  .library-label {
    flex: 1;
    min-width: 0;
  }

  .switcher-divider {
    height: 1px;
    background-color: var(--sl-color-hairline-light);
    margin: 0.75rem 0.5rem 0.5rem;
  }
</style>
