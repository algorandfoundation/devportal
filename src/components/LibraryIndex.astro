---
/**
 * LibraryIndex — Data-driven card grid for the /docs/ landing page.
 *
 * Renders library cards grouped by category, pulling all data from
 * the config system. Adding a new library config automatically adds
 * a card here.
 */
import { getLibrariesByCategory, categoryLabels } from '../config/libraries.ts';
import { libraryLogos } from '../../imports/configs/library-logos.ts';

const categories = getLibrariesByCategory();
const categoryOrder = ['sdk', 'cli', 'language', 'tool', 'api'] as const;
---

{
  categoryOrder.map(cat => {
    const libs = categories[cat];
    if (!libs?.length) return null;
    return (
      <section>
        <h2>{categoryLabels[cat]}</h2>
        <div class='library-cards'>
          {libs.map(lib => {
            const logo = libraryLogos[lib.slug];
            return (
              <a
                href={`/docs/${lib.slug}/`}
                class='library-card'
                aria-label={`${lib.label} documentation`}
              >
                {logo ? (
                  <img
                    src={logo.src}
                    alt=''
                    class='library-logo'
                    width={logo.width}
                    height={logo.height}
                  />
                ) : (
                  <strong>{lib.label}</strong>
                )}
                <p>{lib.description}</p>
              </a>
            );
          })}
        </div>
      </section>
    );
  })
}

<style>
  .library-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin: 1rem 0;
  }

  .library-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.2s,
      background 0.2s;
  }

  .library-card:hover {
    border-color: var(--sl-color-accent);
    background: var(--sl-color-gray-7, rgba(255, 255, 255, 0.03));
  }

  .library-logo {
    height: 28px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    object-position: left center;
  }

  .library-card p {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.8;
  }
</style>
