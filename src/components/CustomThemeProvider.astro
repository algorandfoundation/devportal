---
import Default from '@astrojs/starlight/components/ThemeProvider.astro';
---

<script is:inline>
  if (
    typeof localStorage !== 'undefined' &&
    localStorage.getItem('starlight-theme') == null
  ) {
    localStorage.setItem('starlight-theme', 'dark');
  }
</script>

<script is:inline>
  (function () {
    /**
     * Kapa renders in an open shadow root. Footer copy (Powered by, reCAPTCHA)
     * hard-codes Mantine `c="dimmed"`, which resolves to palette `dark[2]` (#717179).
     * `data-*-color` on the widget script does not override that. When Starlight
     * uses `data-theme="dark"` on `<html>`, remap dimmed inside the widget only.
     *
     * The modal close control is Mantine's ModalBaseCloseButton (`button.m_606cb269`
     * in the current widget bundle); Kapa does not pass `data-modal-close-button-color`
     * into that node, so it is styled the same way here.
     */
    const STYLE_ID = 'devportal-kapa-dimmed-override';

    function starlightDark() {
      return document.documentElement.getAttribute('data-theme') === 'dark';
    }

    function applyKapaDimmedOverride() {
      const host = document.getElementById('kapa-widget-container');
      if (!host || !host.shadowRoot) return;
      let style = host.shadowRoot.getElementById(STYLE_ID);
      if (!style) {
        style = document.createElement('style');
        style.id = STYLE_ID;
        host.shadowRoot.appendChild(style);
      }
      if (starlightDark()) {
        style.textContent =
          '#kapa-widget-root{--mantine-color-dark-2:#ffffff!important;--mantine-color-dimmed:#ffffff!important;}' +
          '#kapa-widget-root button.m_606cb269{color:#ffffff!important;}';
      } else {
        style.textContent = '';
      }
    }

    function observe() {
      new MutationObserver(applyKapaDimmedOverride).observe(
        document.documentElement,
        {
          attributes: true,
          attributeFilter: ['data-theme'],
        },
      );
      new MutationObserver(applyKapaDimmedOverride).observe(document.body, {
        childList: true,
        subtree: false,
      });
    }

    function boot() {
      observe();
      applyKapaDimmedOverride();
      let n = 0;
      const id = window.setInterval(function () {
        applyKapaDimmedOverride();
        if (++n > 120) window.clearInterval(id);
      }, 500);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }
  })();
</script>

<Default {...Astro.props}><slot /></Default>
