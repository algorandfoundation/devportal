---
/**
 * Custom Search component - Algolia-style faceted search mockup.
 *
 * Replaces Starlight's default Pagefind search with a modal that
 * demonstrates faceted search with language filtering and library scoping.
 *
 * This is a UI mockup only — no actual search backend is connected.
 */
import { libraries } from '../config/libraries';
import { langIcons } from '../config/lang-icons';

// Mock search results for demonstration
const mockResults = [
  {
    title: 'Getting Started with AlgoKit',
    path: 'Getting Started > Introduction',
    snippet:
      'AlgoKit is the primary tool used by the Algorand community to develop smart contracts on the Algorand blockchain...',
    section: 'guide',
  },
  {
    title: 'Creating an Application Client',
    path: 'AlgoKit Utils > App Client',
    snippet:
      'The ApplicationClient is a class that wraps the Algorand SDK application calls with a high-level interface...',
    section: 'library',
    library: 'AlgoKit Utils',
  },
  {
    title: 'Smart Contract Development in Python',
    path: 'Algorand Python > Quick Start',
    snippet:
      'Algorand Python allows you to write smart contracts using familiar Python syntax that compiles to AVM bytecode...',
    section: 'library',
    library: 'Algorand Python',
  },
  {
    title: 'Transaction Types and Structure',
    path: 'Concepts > Transactions',
    snippet:
      'Algorand supports several transaction types including payment, asset transfer, application call, and key registration...',
    section: 'guide',
  },
  {
    title: 'Account Management and Rekeying',
    path: 'Concepts > Accounts',
    snippet:
      'Accounts on Algorand are identified by their public key address. Rekeying allows you to change the authorizing key...',
    section: 'guide',
  },
  {
    title: 'Deploying Smart Contracts',
    path: 'AlgoKit Utils > App Deployment',
    snippet:
      'The AppDeployer class provides idempotent deployment of smart contracts, handling create, update, and delete operations...',
    section: 'library',
    library: 'AlgoKit Utils',
  },
  {
    title: 'Writing ARC-4 ABI Methods',
    path: 'Algorand Python > Language Guide > ARC-4',
    snippet:
      'ARC-4 defines a standard ABI for Algorand smart contracts. Use the @abimethod decorator to define ABI-compliant methods...',
    section: 'library',
    library: 'Algorand Python',
  },
  {
    title: 'TypeScript Smart Contract Basics',
    path: 'Algorand TypeScript > Quick Start',
    snippet:
      'Write type-safe Algorand smart contracts using TypeScript syntax. The compiler generates optimized TEAL bytecode...',
    section: 'library',
    library: 'Algorand TypeScript',
  },
];

const isMac = true; // Server-rendered; JS will fix this
---

<faceted-search>
  <!-- Search trigger button (replaces Starlight's default) -->
  <button
    class='search-trigger'
    aria-label='Search'
    aria-keyshortcuts='Control+k'
  >
    <svg
      class='search-trigger-icon'
      width='16'
      height='16'
      viewBox='0 0 16 16'
      fill='none'
      aria-hidden='true'
    >
      <path
        d='M11.5 11.5L14.5 14.5'
        stroke='currentColor'
        stroke-width='1.5'
        stroke-linecap='round'></path>
      <circle cx='7' cy='7' r='5.5' stroke='currentColor' stroke-width='1.5'
      ></circle>
    </svg>
    <span class='search-trigger-label'>Search</span>
    <span class='search-trigger-kbd' aria-hidden='true'>
      <kbd class='platform-key'>Ctrl</kbd><kbd>K</kbd>
    </span>
  </button>

  <!-- Search modal backdrop + dialog -->
  <div class='search-backdrop' aria-hidden='true'>
    <div class='search-dialog' role='dialog' aria-label='Search documentation'>
      <div class='search-dialog-inner'>
        <!-- Search input bar -->
        <div class='search-bar'>
          <!-- Active library filter tag (hidden by default) -->
          <span class='active-library-tag' data-active='false'>
            <span class='active-library-dot'></span>
            <span class='active-library-name'></span>
            <button
              class='active-library-remove'
              aria-label='Remove library filter'
              type='button'
            >
              <svg
                width='12'
                height='12'
                viewBox='0 0 12 12'
                fill='none'
                aria-hidden='true'
              >
                <path
                  d='M3 3L9 9M9 3L3 9'
                  stroke='currentColor'
                  stroke-width='1.5'
                  stroke-linecap='round'></path>
              </svg>
            </button>
          </span>

          <!-- Language picker -->
          <div class='language-picker'>
            <button
              class='language-picker-btn'
              type='button'
              aria-expanded='false'
              aria-haspopup='listbox'
            >
              <span class='language-picker-label'>All Languages</span>
              <svg
                width='10'
                height='10'
                viewBox='0 0 10 10'
                fill='none'
                aria-hidden='true'
              >
                <path
                  d='M2.5 4L5 6.5L7.5 4'
                  stroke='currentColor'
                  stroke-width='1.3'
                  stroke-linecap='round'
                  stroke-linejoin='round'></path>
              </svg>
            </button>
            <ul class='language-dropdown' role='listbox' aria-hidden='true'>
              <li role='option' data-lang='all' class='lang-option active'>
                All Languages
              </li>
              <li role='option' data-lang='TypeScript' class='lang-option'>
                <span class='lang-option-icon' style={`color: ${langIcons.TypeScript.color}`}>
                  <Fragment set:html={langIcons.TypeScript.svg} />
                </span>
                TypeScript
              </li>
              <li role='option' data-lang='Python' class='lang-option'>
                <span class='lang-option-icon' style={`color: ${langIcons.Python.color}`}>
                  <Fragment set:html={langIcons.Python.svg} />
                </span>
                Python
              </li>
              <li role='option' data-lang='Go' class='lang-option'>
                <span class='lang-option-icon' style={`color: ${langIcons.Go.color}`}>
                  <Fragment set:html={langIcons.Go.svg} />
                </span>
                Go
              </li>
            </ul>
          </div>

          <!-- Divider -->
          <span class='search-bar-divider'></span>

          <!-- Search input -->
          <svg
            class='search-input-icon'
            width='16'
            height='16'
            viewBox='0 0 16 16'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M11.5 11.5L14.5 14.5'
              stroke='currentColor'
              stroke-width='1.5'
              stroke-linecap='round'></path>
            <circle
              cx='7'
              cy='7'
              r='5.5'
              stroke='currentColor'
              stroke-width='1.5'></circle>
          </svg>
          <input
            class='search-input'
            type='search'
            placeholder='Search documentation...'
            autocomplete='off'
            autofocus
          />
          <kbd class='search-escape' aria-hidden='true'>Esc</kbd>
        </div>

        <!-- Library facets panel -->
        <div class='facets-panel'>
          <span class='facets-label'>Filter by library:</span>
          <div class='facets-pills'>
            {
              libraries.map(lib => (
                <button
                  class='facet-pill'
                  data-slug={lib.slug}
                  data-color={lib.color}
                  data-label={lib.label}
                  type='button'
                >
                  <span class='facet-dot' style={`background:${lib.color}`} />
                  {lib.label}
                  {lib.languages.length > 0 && (
                    <span class='facet-badges'>
                      {lib.languages.map(lang => {
                        const icon = langIcons[lang];
                        return icon ? (
                          <span class='facet-icon' style={`color: ${icon.color}`} title={lang}>
                            <Fragment set:html={icon.svg} />
                          </span>
                        ) : null;
                      })}
                    </span>
                  )}
                </button>
              ))
            }
          </div>
        </div>

        <!-- Results area -->
        <div class='results-area'>
          <div class='results-empty'></div>
          <ul class='results-list' aria-hidden='true' role='list'>
            {
              mockResults.map(result => (
                <li class='result-item' data-library={result.library || ''}>
                  <a
                    href='#'
                    class='result-link'
                    onclick='event.preventDefault()'
                  >
                    <div class='result-header'>
                      <span class='result-title'>{result.title}</span>
                      {result.library && (
                        <span class='result-library-badge'>
                          {result.library}
                        </span>
                      )}
                    </div>
                    <span class='result-path'>{result.path}</span>
                    <p class='result-snippet'>{result.snippet}</p>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</faceted-search>

<script>
  class FacetedSearch extends HTMLElement {
    private trigger!: HTMLButtonElement;
    private backdrop!: HTMLElement;
    private dialog!: HTMLElement;
    private input!: HTMLInputElement;
    private langBtn!: HTMLButtonElement;
    private langDropdown!: HTMLElement;
    private langLabel!: HTMLElement;
    private facetPills!: NodeListOf<HTMLButtonElement>;
    private activeTag!: HTMLElement;
    private activeTagName!: HTMLElement;
    private activeTagDot!: HTMLElement;
    private activeTagRemove!: HTMLButtonElement;
    private resultsList!: HTMLElement;
    private resultsEmpty!: HTMLElement;
    private selectedLibrary: string | null = null;

    connectedCallback() {
      this.trigger = this.querySelector('.search-trigger')!;
      this.backdrop = this.querySelector('.search-backdrop')!;
      this.dialog = this.querySelector('.search-dialog')!;
      this.input = this.querySelector('.search-input')!;
      this.langBtn = this.querySelector('.language-picker-btn')!;
      this.langDropdown = this.querySelector('.language-dropdown')!;
      this.langLabel = this.querySelector('.language-picker-label')!;
      this.facetPills = this.querySelectorAll('.facet-pill');
      this.activeTag = this.querySelector('.active-library-tag')!;
      this.activeTagName = this.querySelector('.active-library-name')!;
      this.activeTagDot = this.querySelector('.active-library-dot')!;
      this.activeTagRemove = this.querySelector('.active-library-remove')!;
      this.resultsList = this.querySelector('.results-list')!;
      this.resultsEmpty = this.querySelector('.results-empty')!;

      if (!this.trigger || !this.dialog) return;

      // Fix platform key display
      const isMac = /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform);
      const platformKeys = this.querySelectorAll('.platform-key');
      platformKeys.forEach(el => {
        el.textContent = isMac ? '⌘' : 'Ctrl';
      });

      // Open/close
      this.trigger.addEventListener('click', () => this.open());
      this.backdrop.addEventListener('click', e => {
        if (e.target === this.backdrop) this.close();
      });

      // Keyboard shortcut
      document.addEventListener('keydown', e => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          if (this.isOpen()) {
            this.close();
          } else {
            this.open();
          }
        }
        if (e.key === 'Escape' && this.isOpen()) {
          e.preventDefault();
          // Close language dropdown first if open
          if (this.langDropdown.getAttribute('aria-hidden') === 'false') {
            this.closeLangDropdown();
          } else {
            this.close();
          }
        }
      });

      // Language picker
      this.langBtn.addEventListener('click', e => {
        e.stopPropagation();
        this.toggleLangDropdown();
      });
      this.langDropdown.querySelectorAll('.lang-option').forEach(opt => {
        opt.addEventListener('click', e => {
          e.stopPropagation();
          const lang = (opt as HTMLElement).dataset.lang!;
          this.selectLanguage(lang, opt.textContent?.trim() || 'All Languages');
        });
      });

      // Close lang dropdown on outside click
      document.addEventListener('click', () => {
        if (this.langDropdown.getAttribute('aria-hidden') === 'false') {
          this.closeLangDropdown();
        }
      });

      // Library facet pills
      this.facetPills.forEach(pill => {
        pill.addEventListener('click', () => {
          const slug = pill.dataset.slug!;
          const label = pill.dataset.label!;
          const color = pill.dataset.color!;
          if (this.selectedLibrary === slug) {
            this.clearLibraryFilter();
          } else {
            this.selectLibrary(slug, label, color);
          }
        });
      });

      // Remove library tag
      this.activeTagRemove.addEventListener('click', () => {
        this.clearLibraryFilter();
      });

      // Simulate search on input
      this.input.addEventListener('input', () => {
        this.updateResults();
      });
    }

    isOpen() {
      return this.backdrop.getAttribute('aria-hidden') === 'false';
    }

    open() {
      this.backdrop.setAttribute('aria-hidden', 'false');
      this.dialog.classList.add('open');
      requestAnimationFrame(() => this.input.focus());
    }

    close() {
      this.backdrop.setAttribute('aria-hidden', 'true');
      this.dialog.classList.remove('open');
      this.input.value = '';
      this.clearLibraryFilter();
      this.updateResults();
    }

    toggleLangDropdown() {
      const isOpen = this.langDropdown.getAttribute('aria-hidden') === 'false';
      if (isOpen) this.closeLangDropdown();
      else this.openLangDropdown();
    }

    openLangDropdown() {
      this.langDropdown.setAttribute('aria-hidden', 'false');
      this.langBtn.setAttribute('aria-expanded', 'true');
    }

    closeLangDropdown() {
      this.langDropdown.setAttribute('aria-hidden', 'true');
      this.langBtn.setAttribute('aria-expanded', 'false');
    }

    selectLanguage(lang: string, label: string) {
      // Update active state
      this.langDropdown.querySelectorAll('.lang-option').forEach(opt => {
        opt.classList.toggle(
          'active',
          (opt as HTMLElement).dataset.lang === lang,
        );
      });
      // Show just the short label in the button when a specific lang is selected
      if (lang === 'all') {
        this.langLabel.textContent = 'All Languages';
      } else {
        this.langLabel.textContent = label;
      }
      this.closeLangDropdown();
      this.input.focus();
    }

    selectLibrary(slug: string, label: string, color: string) {
      this.selectedLibrary = slug;
      this.activeTagName.textContent = label;
      this.activeTagDot.style.backgroundColor = color;
      this.activeTag.dataset.active = 'true';

      // Highlight selected pill
      this.facetPills.forEach(pill => {
        pill.classList.toggle('selected', pill.dataset.slug === slug);
      });

      this.input.focus();
      this.updateResults();
    }

    clearLibraryFilter() {
      this.selectedLibrary = null;
      this.activeTag.dataset.active = 'false';
      this.facetPills.forEach(pill => pill.classList.remove('selected'));
      this.updateResults();
    }

    updateResults() {
      const query = this.input.value.trim();
      if (query.length > 0) {
        this.resultsList.setAttribute('aria-hidden', 'false');
        this.resultsEmpty.setAttribute('aria-hidden', 'true');
        // Filter results by selected library if any
        const items = this.resultsList.querySelectorAll('.result-item');
        items.forEach(item => {
          const lib = (item as HTMLElement).dataset.library;
          if (this.selectedLibrary) {
            // Show items matching selected library or with no library
            const libLabel = this.activeTagName.textContent;
            (item as HTMLElement).style.display =
              !lib || lib === libLabel ? '' : 'none';
          } else {
            (item as HTMLElement).style.display = '';
          }
        });
      } else {
        this.resultsList.setAttribute('aria-hidden', 'true');
        this.resultsEmpty.setAttribute('aria-hidden', 'false');
      }
    }
  }

  customElements.define('faceted-search', FacetedSearch);
</script>

<style>
  /* Search trigger button */
  faceted-search {
    display: contents;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg-nav);
    color: var(--sl-color-gray-3);
    cursor: pointer;
    font-size: var(--sl-text-sm);
    transition:
      border-color 0.15s,
      color 0.15s;
    min-width: 12rem;
  }

  .search-trigger:hover {
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-gray-2);
  }

  .search-trigger-icon {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .search-trigger-label {
    flex: 1;
    text-align: left;
  }

  .search-trigger-kbd {
    display: none;
    gap: 0.15rem;
    flex-shrink: 0;
  }

  @media (min-width: 50rem) {
    .search-trigger-kbd {
      display: flex;
    }
  }

  .search-trigger-kbd kbd {
    font-family: inherit;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.1rem 0.3rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.2rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
    line-height: 1.3;
  }

  /* Backdrop */
  .search-backdrop {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 5vh;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
  }

  .search-backdrop[aria-hidden='false'] {
    opacity: 1;
    pointer-events: auto;
  }

  /* Dialog */
  .search-dialog {
    position: fixed;
    top: 8vh;
    left: 50%;
    transform: translateX(-50%);
    width: 95vw;
    max-width: 680px;
    max-height: 75vh;
    margin: 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    background: var(--sl-color-bg-nav);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
    padding: 0;
    overflow: hidden;
    color: var(--sl-color-text);
    display: none;
    z-index: 201;
  }

  .search-dialog.open {
    display: block;
  }

  .search-dialog::backdrop {
    display: none;
  }

  .search-dialog-inner {
    display: flex;
    flex-direction: column;
    max-height: 75vh;
  }

  /* Search bar */
  .search-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    flex-shrink: 0;
  }

  /* Active library tag */
  .active-library-tag {
    display: none;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.25rem 0.2rem 0.5rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sl-color-white);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .active-library-tag[data-active='true'] {
    display: flex;
  }

  .active-library-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .active-library-remove {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    padding: 0.1rem;
    border-radius: 0.2rem;
    transition: color 0.15s;
  }

  .active-library-remove:hover {
    color: var(--sl-color-white);
  }

  /* Language picker */
  .language-picker {
    position: relative;
    flex-shrink: 0;
  }

  .language-picker-btn {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.5rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 500;
    white-space: nowrap;
    transition: border-color 0.15s;
  }

  .language-picker-btn:hover {
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-white);
  }

  .language-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 10;
    min-width: 160px;
    margin-top: 0.35rem;
    padding: 0.3rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    list-style: none;
    display: none;
  }

  .language-dropdown[aria-hidden='false'] {
    display: block;
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.5rem;
    border-radius: 0.25rem;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    font-size: var(--sl-text-sm);
    transition: background-color 0.1s;
  }

  .lang-option:hover {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
  }

  .lang-option.active {
    color: var(--sl-color-white);
    font-weight: 600;
  }

  .lang-option-icon {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    line-height: 0;
  }

  .lang-option-icon :global(svg) {
    width: 14px;
    height: 14px;
  }

  /* Search bar divider */
  .search-bar-divider {
    width: 1px;
    height: 1.25rem;
    background: var(--sl-color-gray-5);
    flex-shrink: 0;
  }

  /* Search input */
  .search-input-icon {
    flex-shrink: 0;
    color: var(--sl-color-gray-3);
  }

  .search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--sl-color-white);
    font-size: var(--sl-text-base);
    min-width: 0;
  }

  .search-input::placeholder {
    color: var(--sl-color-gray-4);
  }

  .search-escape {
    flex-shrink: 0;
    font-family: inherit;
    font-size: 0.6rem;
    font-weight: 600;
    padding: 0.1rem 0.35rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.2rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-gray-3);
    line-height: 1.3;
  }

  /* Facets panel */
  .facets-panel {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
    flex-shrink: 0;
  }

  .facets-label {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    margin-right: 0.2rem;
  }

  .facets-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .facet-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1rem;
    background: transparent;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    font-size: 0.72rem;
    font-weight: 500;
    white-space: nowrap;
    transition:
      border-color 0.15s,
      background-color 0.15s,
      color 0.15s;
  }

  .facet-pill:hover {
