# ─────────────────────────────────────────────────────────────
# Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────

# GitHub API token (required for importing docs from external repos)
# GITHUB_TOKEN=

# Content import flags
# IMPORT_GITHUB=false
# IMPORT_DRY_RUN=false
# FORCE_IMPORT=false

# Kapa.ai integration ID for the AI chat panel (optional)
# PUBLIC_KAPA_INTEGRATION_ID=

# Prose checker (optional, disabled by default)
# OPENAI_API_KEY=
# PROSE_CHECK_ENABLED=false
# PROSE_CHECK_MODE=warn
# PROSE_CHECK_MODEL=gpt-4o-mini
# PROSE_CHECK_SENSITIVITY=medium
# PROSE_CHECK_EXCLUDE=src/content/docs/reference/
