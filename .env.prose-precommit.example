# ─────────────────────────────────────────────────────────────
# Prose Check Configuration
# Pre-commit hook that reviews Markdown docs for grammar/style
# ─────────────────────────────────────────────────────────────

# Enable/disable the hook entirely (default: true)
# PROSE_CHECK_ENABLED=true

# OpenAI API key (required)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Mode: "fail" blocks commits with issues, "warn" allows them
PROSE_CHECK_MODE=warn

# Model: Any OpenAI chat model (gpt-4o-mini, gpt-4o, gpt-5, gpt-5-mini, o3-mini, etc.)
PROSE_CHECK_MODEL=gpt-4o-mini

# Sensitivity: low (obvious errors only), medium (balanced), high (thorough)
# PROSE_CHECK_SENSITIVITY=medium

# Exclude paths: comma-separated list of folder/file paths to skip
# PROSE_CHECK_EXCLUDE=algokit/cli,arcs/
