{
  "name": "@algorandfoundation/devportal-docs",
  "version": "0.1.0",
  "description": "CLI tools, types, and theme for publishing library docs to the Algorand Developer Portal",
  "type": "module",
  "exports": {
    ".": "./dist/cli.js",
    "./types": "./dist/types.js",
    "./theme": "./theme/index.js"
  },
  "bin": {
    "devportal-docs": "./dist/cli.js"
  },
  "files": [
    "dist",
    "theme"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "tsx": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/algorandfoundation/devportal.git",
    "directory": "packages/devportal-docs"
  },
  "publishConfig": {
    "access": "public"
  }
}
